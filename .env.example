# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored and never committed.

# ── Required ─────────────────────────────────────────────────────────────────

# Absolute path to the root folder containing your past papers.
# The scanner expects two subfolders inside it:
#   - "Past Tripos Papers-*/"                    (question papers)
#   - "Past Tripos Papers - Suggested Answers-*/" (mark schemes)
# Note: past papers are copyright their respective owners and are NOT included
# in this repo. Point this at your own local copy.
PAPERS_ROOT=/path/to/your/papers/folder

# ── Optional ─────────────────────────────────────────────────────────────────

# Where the SQLite database file lives (relative to project root).
# Defaults to data/tracker.db if unset.
DATABASE_PATH=data/tracker.db

# Your exam date (ISO format, e.g. 2026-06-01) — powers the dashboard countdown.
EXAM_DATE=

# Set to "true" to enable the optional Claude planner feature.
# Requires the Claude Code CLI to be installed and authenticated.
# Leave unset/false to run the app with no AI dependency.
CLAUDE_PLANNER_ENABLED=false
